# BrainScan deploy env-vars для TimeWebCloud VPS.
# Скопируй в `deploy/.env` на сервере и заполни актуальными значениями.
# Файл .env держим только на сервере — в git его НЕТ.

# --- Environment ---
APP_ENV=dev

# --- Domain + TLS (Let's Encrypt) ---
API_DOMAIN=dev-api.your-domain.com
LETSENCRYPT_EMAIL=you@your-domain.com

# --- Managed Postgres (TimeWebCloud) ---
# TLS: asyncpg использует ?ssl=require, psycopg2 — ?sslmode=require. Без cert-проверки
# (verify-full потребует положить root.crt в контейнер и переключить на ?sslmode=verify-full +
# подменить ssl context). Пароль в DSN — URL-encoded (спецсимволы вроде ^$*| кодируются).
DATABASE_URL=postgresql+asyncpg://USER:URL_ENCODED_PASSWORD@HOST:5432/DB?ssl=require
ALEMBIC_DATABASE_URL=postgresql+psycopg2://USER:URL_ENCODED_PASSWORD@HOST:5432/DB?sslmode=require

# --- Auth (генерируется: openssl rand -hex 32) ---
JWT_SECRET=
JWT_ACCESS_TTL_SECONDS=1800
JWT_REFRESH_TTL_SECONDS=2592000

# --- Managed S3 (TimeWebCloud Object Storage) ---
# Если у тебя один бакет (например, UUID), пропиши его во все три переменные —
# ключи в коде уникальны (UUID-пути), коллизий не будет. Можно и три отдельных.
S3_ENDPOINT_URL=https://s3.twcstorage.ru
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=ru-1
S3_BUCKET_SCREENSHOTS=YOUR_BUCKET
S3_BUCKET_LOCALIZE=YOUR_BUCKET
S3_BUCKET_MODELS=YOUR_BUCKET

# --- Redis (self-hosted в этом же compose) ---
REDIS_URL=redis://redis:6379/0

# --- App ---
APP_VERSION=0.1.0
LOG_LEVEL=INFO
CORS_DEV=false
