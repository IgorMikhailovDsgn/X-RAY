# BrainScan deploy env-vars для TimeWebCloud VPS.
# Скопируй в `deploy/.env` на сервере и заполни актуальными значениями.
# Файл .env держим только на сервере — в git его НЕТ.

# --- Environment ---
APP_ENV=dev

# --- Domain + TLS (Let's Encrypt) ---
API_DOMAIN=dev-api.your-domain.com
LETSENCRYPT_EMAIL=you@your-domain.com

# --- Managed Postgres (TimeWebCloud, приватный endpoint) ---
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@PRIVATE_HOST:5432/brainscan
ALEMBIC_DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@PRIVATE_HOST:5432/brainscan

# --- Auth (генерируется: openssl rand -hex 32) ---
JWT_SECRET=
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# --- Managed S3 (TimeWebCloud Object Storage, приватный endpoint) ---
S3_ENDPOINT_URL=https://s3.timeweb.cloud
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=ru-1
S3_BUCKET_SCREENSHOTS=brainscan-screenshots
S3_BUCKET_LOCALIZE=brainscan-localize
S3_BUCKET_MODELS=brainscan-models

# --- Redis (self-hosted в этом же compose) ---
REDIS_URL=redis://redis:6379/0

# --- App ---
APP_VERSION=0.1.0
LOG_LEVEL=INFO
CORS_DEV=false
