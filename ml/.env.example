# --- Environment ---
# local | dev | stage | prod. В non-local средах REDIS_URL обязателен.
APP_ENV=local

# --- Celery broker / result backend ---
REDIS_URL=redis://localhost:6379/0

# --- БД (для чтения accumulated annotations при сборке датасета) ---
DATABASE_URL=postgresql+psycopg2://brainscan:brainscan_dev@localhost:5432/brainscan

# --- S3-compatible (артефакты моделей, манифесты датасетов) ---
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=brainscan
S3_SECRET_KEY=brainscan_dev_secret
S3_BUCKET_MODELS=models
S3_BUCKET_DATASETS=datasets

# --- MLflow ---
MLFLOW_TRACKING_URI=http://localhost:5000

# --- Feature flags ---
# В MVP реальная тренировка отключена (моделей нет). Stub-таски логируют запуск
# в MLflow, регистрируют dummy artifact и создают row в models со status='candidate'.
ENABLE_REAL_TRAINING=false

# Триггер дообучения: минимум новых аннотаций с последнего датасета
RETRAIN_THRESHOLD=1000
