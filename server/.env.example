# --- Database ---
DATABASE_URL=postgresql+asyncpg://brainscan:brainscan_dev@localhost:5432/brainscan
ALEMBIC_DATABASE_URL=postgresql+psycopg2://brainscan:brainscan_dev@localhost:5432/brainscan

# --- Auth (generate via: openssl rand -hex 32) ---
JWT_SECRET=change-me-to-a-32-byte-hex-string
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# --- S3-compatible storage ---
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=brainscan
S3_SECRET_KEY=brainscan_dev_secret
S3_REGION=us-east-1
S3_BUCKET_SCREENSHOTS=screenshots
S3_BUCKET_LOCALIZE=localize
S3_BUCKET_MODELS=models

# --- Celery / Redis ---
REDIS_URL=redis://localhost:6379/0

# --- App ---
APP_VERSION=0.1.0
LOG_LEVEL=INFO

# Включает CORS allow-all (только для Swagger UI / локальной отладки).
CORS_DEV=false
